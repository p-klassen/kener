# =============================================================================
# Kener v4 — Environment Variables
#
# Copy this file to .env and fill in all REQUIRED values.
# Optional variables can remain commented out — Kener uses sensible defaults.
#
# Generate a secret key: openssl rand -base64 32
# =============================================================================

# ===========================================================================
# REQUIRED
# ===========================================================================

# Secret key for JWT signing and CSRF protection.
# Set once and never change — all active sessions and links become invalid.
KENER_SECRET_KEY=replace_me_with_a_random_string

# Public URL where Kener is reachable (with protocol, no trailing slash).
# Used for OAuth callbacks, email links, and CSRF validation.
# Examples: https://status.example.com  |  http://localhost:3000
ORIGIN=http://localhost:3000

# Redis connection URL. Required for BullMQ queues and the scheduler.
# Format: redis://[user:password@]host[:port][/db]
REDIS_URL=redis://localhost:6379

# ===========================================================================
# DATABASE (optional — defaults to SQLite)
# ===========================================================================

# SQLite (default, no separate database server needed):
# DATABASE_URL=sqlite://./database/kener.sqlite.db

# PostgreSQL:
# DATABASE_URL=postgresql://kener:password@localhost:5432/kener

# MySQL / MariaDB:
# DATABASE_URL=mysql://kener:password@localhost:3306/kener

# ===========================================================================
# INITIAL ADMIN USER (optional — only used on first start)
# If both are set, Kener creates an admin account automatically.
# Remove after first successful login.
# ===========================================================================

# KENER_ADMIN_EMAIL=admin@example.com
# KENER_ADMIN_PASSWORD=change_me_min_8_chars

# ===========================================================================
# EMAIL — Option A: Resend (https://resend.com)
# ===========================================================================

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_SENDER_EMAIL=kener@example.com

# ===========================================================================
# EMAIL — Option B: SMTP
# ===========================================================================

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=kener@example.com
# SMTP_PASSWORD=smtp_password
# SMTP_SECURE=0                              # 0=STARTTLS (587), 1=SSL/TLS (465)
# SMTP_SENDER=Kener Status <kener@example.com>

# ===========================================================================
# SERVER & ROUTING (optional)
# ===========================================================================

# Internal HTTP port (default: 3000).
# PORT=3000

# Base path when Kener runs under a sub-path, e.g. /status.
# Leave empty when running at / (default).
# ORIGIN and KENER_BASE_PATH must match: https://example.com/status + /status
# KENER_BASE_PATH=

# Maximum request body size for file uploads (default: 3M).
# BODY_SIZE_LIMIT=3M

# Container timezone (default: UTC). Valid values: IANA timezone names.
# TZ=UTC
# TZ=Europe/Berlin
